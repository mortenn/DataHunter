<Window
	x:Class="DataHunter.MainWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:v="clr-namespace:DataHunter.View"
	xmlns:vm="clr-namespace:DataHunter.ViewModel"
	Title="DataHunter"
	Width="1200"
	Height="760"
	MinWidth="900"
	MinHeight="560"
	Background="{DynamicResource WindowBackgroundBrush}"
	Foreground="{DynamicResource ForegroundBrush}"
	Icon="app.ico"
	PreviewMouseDown="Window_OnPreviewMouseDown"
	mc:Ignorable="d">

	<Window.DataContext>
		<vm:AppContext />
	</Window.DataContext>

	<Window.Resources>

		<v:FormatKbSizeConverter x:Key="FormatKbSizeConverter" />
		<BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

		<Style x:Key="MonospaceCellTextStyle" TargetType="TextBlock">
			<Setter Property="FontFamily" Value="Cascadia Mono, Consolas" />
		</Style>

		<Style x:Key="RightAlignedMonospaceCellTextStyle" BasedOn="{StaticResource MonospaceCellTextStyle}" TargetType="TextBlock">
			<Setter Property="HorizontalAlignment" Value="Stretch" />
			<Setter Property="TextAlignment" Value="Right" />
		</Style>

		<Style x:Key="ThemeToggleButtonStyle" TargetType="Button">
			<Setter Property="Background" Value="Transparent" />
			<Setter Property="BorderThickness" Value="0" />
			<Setter Property="Padding" Value="0" />
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<ContentPresenter />
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<Style x:Key="LandingShortcutButtonStyle" TargetType="Button">
			<Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
			<Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
			<Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
			<Setter Property="BorderThickness" Value="1" />
			<Setter Property="Padding" Value="18,14" />
			<Setter Property="HorizontalContentAlignment" Value="Stretch" />
			<Setter Property="VerticalContentAlignment" Value="Stretch" />
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border
							x:Name="Root"
							Background="{TemplateBinding Background}"
							BorderBrush="{TemplateBinding BorderBrush}"
							BorderThickness="{TemplateBinding BorderThickness}"
							CornerRadius="6"
							SnapsToDevicePixels="True">
							<ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter TargetName="Root" Property="Background" Value="{DynamicResource HoverBrush}" />
							</Trigger>
							<Trigger Property="IsPressed" Value="True">
								<Setter TargetName="Root" Property="Background" Value="{DynamicResource DataGridRowSelectedBrush}" />
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<Style x:Key="ShareProgressBarStyle" TargetType="ProgressBar">
			<Setter Property="Minimum" Value="0" />
			<Setter Property="Maximum" Value="1" />
			<Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
			<Setter Property="Background" Value="Transparent" />
			<Setter Property="BorderThickness" Value="0" />
			<Setter Property="IsHitTestVisible" Value="False" />
			<Setter Property="Opacity" Value="0.38" />
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="ProgressBar">
						<Grid Background="{TemplateBinding Background}" ClipToBounds="True">
							<Border x:Name="PART_Track" Background="{TemplateBinding Background}" />
							<Border x:Name="PART_Indicator" HorizontalAlignment="Left" Background="{TemplateBinding Foreground}" />
						</Grid>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<HierarchicalDataTemplate DataType="{x:Type vm:MyPc}" ItemsSource="{Binding Drives}">
			<TextBlock Text="{Binding Name}" />
		</HierarchicalDataTemplate>

		<HierarchicalDataTemplate DataType="{x:Type vm:Drive}" ItemsSource="{Binding Folders}">
			<StackPanel Orientation="Horizontal">
				<TextBlock Foreground="Red" Text="⊘ ">
					<TextBlock.Style>
						<Style TargetType="TextBlock">
							<Style.Triggers>
								<DataTrigger Binding="{Binding AccessDenied}" Value="False">
									<Setter Property="TextBlock.Visibility" Value="Collapsed" />
								</DataTrigger>
							</Style.Triggers>
						</Style>
					</TextBlock.Style>
				</TextBlock>
				<Grid Width="16" Height="16" Margin="0,0,5,0">
					<Grid.Style>
						<Style TargetType="Grid">
							<Setter Property="Visibility" Value="Collapsed" />
							<Style.Triggers>
								<DataTrigger Binding="{Binding HasActiveScan}" Value="True">
									<Setter Property="Visibility" Value="Visible" />
								</DataTrigger>
							</Style.Triggers>
						</Style>
					</Grid.Style>
					<Path
						Width="16"
						Height="16"
						Data="M 8,2 A 6,6 0 1 1 2,8"
						Stretch="None"
						Stroke="{DynamicResource AccentBrush}"
						StrokeEndLineCap="Round"
						StrokeStartLineCap="Round"
						StrokeThickness="2">
						<Path.RenderTransform>
							<RotateTransform CenterX="8" CenterY="8" />
						</Path.RenderTransform>
						<Path.Triggers>
							<EventTrigger RoutedEvent="Loaded">
								<BeginStoryboard>
									<Storyboard RepeatBehavior="Forever">
										<DoubleAnimation Storyboard.TargetProperty="RenderTransform.Angle" From="0" To="360" Duration="0:0:1" />
									</Storyboard>
								</BeginStoryboard>
							</EventTrigger>
						</Path.Triggers>
					</Path>
				</Grid>
				<TextBlock Text="{Binding Info.Name}" />
			</StackPanel>
		</HierarchicalDataTemplate>

		<HierarchicalDataTemplate DataType="{x:Type vm:Folder}" ItemsSource="{Binding Folders}">
			<StackPanel Orientation="Horizontal">
				<TextBlock Foreground="Red" Text="⊘ ">
					<TextBlock.Style>
						<Style TargetType="TextBlock">
							<Style.Triggers>
								<DataTrigger Binding="{Binding AccessDenied}" Value="False">
									<Setter Property="TextBlock.Visibility" Value="Collapsed" />
								</DataTrigger>
							</Style.Triggers>
						</Style>
					</TextBlock.Style>
				</TextBlock>
				<Grid Width="14" Height="14" Margin="0,0,5,0">
					<Grid.Style>
						<Style TargetType="Grid">
							<Setter Property="Visibility" Value="Collapsed" />
							<Style.Triggers>
								<DataTrigger Binding="{Binding Scanning}" Value="True">
									<Setter Property="Visibility" Value="Visible" />
								</DataTrigger>
							</Style.Triggers>
						</Style>
					</Grid.Style>
					<Path
						Width="14"
						Height="14"
						Data="M 7,1 A 6,6 0 1 1 1,7"
						Stretch="None"
						Stroke="{DynamicResource AccentBrush}"
						StrokeEndLineCap="Round"
						StrokeStartLineCap="Round"
						StrokeThickness="2">
						<Path.RenderTransform>
							<RotateTransform CenterX="7" CenterY="7" />
						</Path.RenderTransform>
						<Path.Triggers>
							<EventTrigger RoutedEvent="Loaded">
								<BeginStoryboard>
									<Storyboard RepeatBehavior="Forever">
										<DoubleAnimation Storyboard.TargetProperty="RenderTransform.Angle" From="0" To="360" Duration="0:0:1" />
									</Storyboard>
								</BeginStoryboard>
							</EventTrigger>
						</Path.Triggers>
					</Path>
				</Grid>
				<Grid Width="16" Height="16" Margin="0,0,5,0">
					<Path
						Data="M 2,5 L 7,5 L 8,6 L 14,6 L 14,13 L 2,13 Z"
						Fill="Transparent"
						Stroke="{DynamicResource SecondaryForegroundBrush}"
						StrokeLineJoin="Round"
						StrokeThickness="1.2" />
					<Grid.Style>
						<Style TargetType="Grid">
							<Setter Property="Visibility" Value="Visible" />
							<Style.Triggers>
								<DataTrigger Binding="{Binding Scanning}" Value="True">
									<Setter Property="Visibility" Value="Collapsed" />
								</DataTrigger>
							</Style.Triggers>
						</Style>
					</Grid.Style>
				</Grid>
				<!--<TextBlock Text="📁" Margin="0,0,5,0">
					<TextBlock.Style>
						<Style TargetType="TextBlock">
							<Setter Property="Visibility" Value="Visible" />
							<Style.Triggers>
								<DataTrigger Binding="{Binding Scanning}" Value="True">
									<Setter Property="Visibility" Value="Collapsed" />
								</DataTrigger>
							</Style.Triggers>
						</Style>
					</TextBlock.Style>
				</TextBlock>-->
				<TextBlock Text="{Binding Info.Name}">
					<TextBlock.Style>
						<Style>
							<Style.Triggers>
								<DataTrigger Binding="{Binding IsVirtual}" Value="True">
									<Setter Property="TextBlock.Opacity" Value="0.5" />
								</DataTrigger>
							</Style.Triggers>
						</Style>
					</TextBlock.Style>
				</TextBlock>
			</StackPanel>
		</HierarchicalDataTemplate>

		<Style BasedOn="{StaticResource {x:Type TreeViewItem}}" TargetType="{x:Type TreeViewItem}">
			<Setter Property="IsExpanded" Value="{Binding IsExpanded}" />
			<Setter Property="IsSelected" Value="{Binding IsSelected}" />
		</Style>

	</Window.Resources>
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="250" />
			<ColumnDefinition Width="Auto" />
			<ColumnDefinition />
		</Grid.ColumnDefinitions>

		<TreeView Name="TreeView" Grid.Column="0" ItemsSource="{Binding TreeRoots}" SelectedItemChanged="TreeView_OnSelectedItemChanged" />

		<GridSplitter
			Grid.Column="1"
			Width="4"
			HorizontalAlignment="Center"
			VerticalAlignment="Stretch"
			Background="{DynamicResource BorderBrush}"
			ShowsPreview="True" />

		<Grid Background="{DynamicResource WindowBackgroundBrush}" Column="2">
			<Grid.Style>
				<Style>
					<Setter Property="UIElement.Visibility" Value="Collapsed" />
					<Style.Triggers>
						<DataTrigger Binding="{Binding SelectedFolder}" Value="{x:Null}">
							<Setter Property="UIElement.Visibility" Value="Visible" />
						</DataTrigger>
					</Style.Triggers>
				</Style>
			</Grid.Style>

			<StackPanel Width="520" HorizontalAlignment="Center" VerticalAlignment="Center">
				<TextBlock
					Margin="0,0,0,8"
					FontSize="24"
					FontWeight="SemiBold"
					Foreground="{DynamicResource ForegroundBrush}"
					Text="Where should DataHunter look first?" />
				<TextBlock Margin="0,0,0,24" FontSize="14" Foreground="{DynamicResource SecondaryForegroundBrush}" Text="Pick a common hot spot, or choose a drive from the tree." />
				<ItemsControl ItemsSource="{Binding LandingShortcuts}">
					<ItemsControl.ItemsPanel>
						<ItemsPanelTemplate>
							<UniformGrid Columns="2" />
						</ItemsPanelTemplate>
					</ItemsControl.ItemsPanel>
					<ItemsControl.ItemTemplate>
						<DataTemplate>
							<Button Margin="4" AutomationProperties.Name="{Binding Title}" Click="LandingShortcut_OnClick" Style="{StaticResource LandingShortcutButtonStyle}">
								<Grid HorizontalAlignment="Stretch">
									<Grid.RowDefinitions>
										<RowDefinition Height="Auto" />
										<RowDefinition Height="Auto" />
										<RowDefinition Height="Auto" />
									</Grid.RowDefinitions>
									<TextBlock HorizontalAlignment="Left" FontSize="14" FontWeight="SemiBold" Text="{Binding Title}" />
									<TextBlock
										Grid.Row="1"
										Margin="0,4,0,0"
										HorizontalAlignment="Left"
										Foreground="{DynamicResource SecondaryForegroundBrush}"
										Text="{Binding Description}"
										TextWrapping="Wrap" />
									<TextBlock
										Grid.Row="2"
										Margin="0,8,0,0"
										HorizontalAlignment="Left"
										FontFamily="Cascadia Mono, Consolas"
										FontSize="11"
										Foreground="{DynamicResource SecondaryForegroundBrush}"
										Text="{Binding FullName}"
										TextTrimming="CharacterEllipsis" />
								</Grid>
							</Button>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>
			</StackPanel>

		</Grid>

		<Grid Grid.Column="2" Background="{DynamicResource WindowBackgroundBrush}">
			<Grid.Style>
				<Style>
					<Setter Property="UIElement.Visibility" Value="Collapsed" />
					<Style.Triggers>
						<DataTrigger Binding="{Binding SelectedFolder.AccessDenied}" Value="True">
							<Setter Property="UIElement.Visibility" Value="Visible" />
						</DataTrigger>
					</Style.Triggers>
				</Style>
			</Grid.Style>
			<TextBlock
				HorizontalAlignment="Center"
				VerticalAlignment="Center"
				FontSize="14"
				Foreground="Red"
				Text="⊘ Access Denied" />
		</Grid>

		<Grid Grid.Column="2">
			<Grid.Style>
				<Style>
					<Style.Triggers>
						<DataTrigger Binding="{Binding SelectedFolder}" Value="{x:Null}">
							<Setter Property="UIElement.Visibility" Value="Collapsed" />
						</DataTrigger>
						<DataTrigger Binding="{Binding SelectedFolder.AccessDenied}" Value="True">
							<Setter Property="UIElement.Visibility" Value="Collapsed" />
						</DataTrigger>
					</Style.Triggers>
				</Style>
			</Grid.Style>
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
				<RowDefinition />
			</Grid.RowDefinitions>

			<StackPanel Grid.Row="0" Margin="8,8,8,4" Background="Transparent" Orientation="Horizontal">
				<Button
					Margin="2"
					AutomationProperties.Name="Navigate back"
					Command="{Binding NavigateCommand}"
					Content="⬑"
					FontSize="16" />
				<Button
					Margin="0,2"
					AutomationProperties.Name="Refresh selected folder"
					Command="{Binding RefreshCommand}"
					Content="↻"
					FontSize="16" />
				<Button Margin="0,2" Command="{Binding OpenCommand}" Content="Open in explorer" FontSize="16" />
			</StackPanel>

			<ListBox Grid.Row="1" ItemsSource="{Binding SelectedFolder.Path}" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Disabled">
				<ListBox.ItemsPanel>
					<ItemsPanelTemplate>
						<StackPanel Orientation="Horizontal" />
					</ItemsPanelTemplate>
				</ListBox.ItemsPanel>
				<ListBox.ItemTemplate>
					<DataTemplate>
						<Button
							Margin="0"
							Background="Transparent"
							BorderBrush="Transparent"
							Click="NavigateAction"
							Content="{Binding Info.Name}"
							FontSize="16" />
					</DataTemplate>
				</ListBox.ItemTemplate>
			</ListBox>

			<StackPanel
				Grid.Row="2"
				Margin="8,4"
				Background="Transparent"
				Orientation="Horizontal"
				TextBlock.FontSize="14"
				TextBlock.Foreground="{DynamicResource ForegroundBrush}">
				<TextBlock Margin="0,2" FontSize="14" Text="Files in this folder: " />
				<TextBlock Margin="0,2" FontSize="14" Text="{Binding SelectedFolder.Files, Converter={StaticResource FormatKbSizeConverter}}" />
				<TextBlock Margin="0,2" FontSize="14" Text=" Including subfolders: " />
				<TextBlock Margin="0,2" FontSize="14" Text="{Binding SelectedFolder.Bytes, Converter={StaticResource FormatKbSizeConverter}}" />
			</StackPanel>

			<Grid Grid.Row="3">
				<Grid.ColumnDefinitions>
					<ColumnDefinition />
					<ColumnDefinition Width="Auto" />
					<ColumnDefinition Width="Auto" />
				</Grid.ColumnDefinitions>

				<Grid Grid.Column="0">
					<DataGrid
						AutoGenerateColumns="False"
						EnableColumnVirtualization="True"
						EnableRowVirtualization="True"
						ItemsSource="{Binding Content}"
						ScrollViewer.CanContentScroll="True"
						SelectedItem="{Binding SelectedContentFolder, Mode=TwoWay}"
						VirtualizingPanel.IsVirtualizing="True"
						VirtualizingPanel.VirtualizationMode="Recycling">
						<DataGrid.Style>
							<Style BasedOn="{StaticResource {x:Type DataGrid}}" TargetType="DataGrid">
								<Style.Triggers>
									<DataTrigger Binding="{Binding IsContentLoadDeferred}" Value="True">
										<Setter Property="Visibility" Value="Collapsed" />
									</DataTrigger>
								</Style.Triggers>
							</Style>
						</DataGrid.Style>
						<DataGrid.Columns>
							<DataGridTextColumn Binding="{Binding Info.Name}" ElementStyle="{StaticResource MonospaceCellTextStyle}" Header="Folder" IsReadOnly="True" />
							<DataGridTextColumn
								Binding="{Binding Bytes, Converter={StaticResource FormatKbSizeConverter}}"
								ElementStyle="{StaticResource RightAlignedMonospaceCellTextStyle}"
								Header="Size"
								IsReadOnly="True"
								SortDirection="Descending" />
							<DataGridTextColumn Binding="{Binding DiskSharePercent, StringFormat={}{0:0.00}%}" ElementStyle="{StaticResource RightAlignedMonospaceCellTextStyle}" Header="% of disk" IsReadOnly="True" />
						</DataGrid.Columns>
						<DataGrid.RowStyle>
							<Style BasedOn="{StaticResource {x:Type DataGridRow}}" TargetType="DataGridRow">
								<EventSetter Event="MouseDoubleClick" Handler="NavigateAction" />
								<Setter Property="Template">
									<Setter.Value>
										<ControlTemplate TargetType="DataGridRow">
											<Border BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" SnapsToDevicePixels="True">
												<Grid>
													<ProgressBar Value="{Binding ShareOfParent, Mode=OneWay}">
														<ProgressBar.Style>
															<Style BasedOn="{StaticResource ShareProgressBarStyle}" TargetType="ProgressBar">
																<Style.Triggers>
																	<DataTrigger Binding="{Binding HasReliableShareOfParent}" Value="False">
																		<Setter Property="Visibility" Value="Collapsed" />
																	</DataTrigger>
																</Style.Triggers>
															</Style>
														</ProgressBar.Style>
													</ProgressBar>
													<SelectiveScrollingGrid>
														<SelectiveScrollingGrid.ColumnDefinitions>
															<ColumnDefinition Width="Auto" />
															<ColumnDefinition Width="*" />
														</SelectiveScrollingGrid.ColumnDefinitions>
														<SelectiveScrollingGrid.RowDefinitions>
															<RowDefinition Height="*" />
															<RowDefinition Height="Auto" />
														</SelectiveScrollingGrid.RowDefinitions>
														<DataGridCellsPresenter Grid.Column="1" ItemsPanel="{TemplateBinding ItemsPanel}" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
														<DataGridDetailsPresenter Grid.Row="1" Grid.Column="1" SelectiveScrollingGrid.SelectiveScrollingOrientation="{Binding AreRowDetailsFrozen, ConverterParameter={x:Static SelectiveScrollingOrientation.Vertical}, Converter={x:Static DataGrid.RowDetailsScrollingConverter}, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}" Visibility="{TemplateBinding DetailsVisibility}" />
														<DataGridRowHeader Grid.RowSpan="2" SelectiveScrollingGrid.SelectiveScrollingOrientation="Vertical" Visibility="{Binding HeadersVisibility, ConverterParameter={x:Static DataGridHeadersVisibility.Row}, Converter={x:Static DataGrid.HeadersVisibilityConverter}, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}" />
													</SelectiveScrollingGrid>
												</Grid>
											</Border>
										</ControlTemplate>
									</Setter.Value>
								</Setter>
								<Style.Triggers>
									<DataTrigger Binding="{Binding Scanning}" Value="True">
										<Setter Property="TextBlock.FontStyle" Value="Italic" />
										<Setter Property="TextBlock.Opacity" Value="0.5" />
									</DataTrigger>
									<DataTrigger Binding="{Binding Canceled}" Value="True">
										<Setter Property="TextBlock.FontStyle" Value="Italic" />
										<Setter Property="TextBlock.Opacity" Value="0.55" />
									</DataTrigger>
									<DataTrigger Binding="{Binding AccessDenied}" Value="True">
										<Setter Property="TextBlock.Opacity" Value="0.5" />
									</DataTrigger>
									<DataTrigger Binding="{Binding IsVirtual}" Value="True">
										<Setter Property="TextBlock.Opacity" Value="0.5" />
									</DataTrigger>
								</Style.Triggers>
							</Style>
						</DataGrid.RowStyle>
					</DataGrid>
					<Grid Visibility="{Binding IsContentLoadDeferred, Converter={StaticResource BooleanToVisibilityConverter}}">
						<StackPanel Width="420" HorizontalAlignment="Center" VerticalAlignment="Center">
							<TextBlock
								Margin="0,0,0,8"
								FontSize="22"
								FontWeight="SemiBold"
								Foreground="{DynamicResource ForegroundBrush}"
								Text="Large folder" />
							<TextBlock Margin="0,0,0,18" Foreground="{DynamicResource SecondaryForegroundBrush}" Text="{Binding ContentLoadWarningText}" TextWrapping="Wrap" />
							<Button Padding="14,6" HorizontalAlignment="Left" Click="LoadLargeFolderTable_OnClick" Content="Load table anyway" />
						</StackPanel>
					</Grid>
				</Grid>

				<Grid Grid.Column="1" Width="20">
					<GridSplitter Width="4" HorizontalAlignment="Center" VerticalAlignment="Stretch" ShowsPreview="True" />
					<ToggleButton
						Width="18"
						Height="28"
						Margin="0,8,0,0"
						HorizontalAlignment="Center"
						VerticalAlignment="Top"
						AutomationProperties.Name="Show or hide details"
						IsChecked="{Binding IsDetailPaneExpanded, Mode=TwoWay}"
						ToolTip="Show or hide details">
						<ToggleButton.Style>
							<Style TargetType="ToggleButton">
								<Setter Property="Content" Value="‹" />
								<Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
								<Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
								<Setter Property="Foreground" Value="{DynamicResource SecondaryForegroundBrush}" />
								<Setter Property="BorderThickness" Value="1" />
								<Setter Property="Template">
									<Setter.Value>
										<ControlTemplate TargetType="ToggleButton">
											<Border
												x:Name="Root"
												Background="{TemplateBinding Background}"
												BorderBrush="{TemplateBinding BorderBrush}"
												BorderThickness="{TemplateBinding BorderThickness}"
												CornerRadius="9">
												<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
											</Border>
											<ControlTemplate.Triggers>
												<Trigger Property="IsMouseOver" Value="True">
													<Setter TargetName="Root" Property="Background" Value="{DynamicResource HoverBrush}" />
												</Trigger>
											</ControlTemplate.Triggers>
										</ControlTemplate>
									</Setter.Value>
								</Setter>
								<Style.Triggers>
									<Trigger Property="IsChecked" Value="True">
										<Setter Property="Content" Value="›" />
									</Trigger>
								</Style.Triggers>
							</Style>
						</ToggleButton.Style>
					</ToggleButton>
				</Grid>

				<Grid Grid.Column="2">
					<Grid.Style>
						<Style TargetType="Grid">
							<Setter Property="Width" Value="320" />
							<Style.Triggers>
								<DataTrigger Binding="{Binding IsDetailPaneExpanded}" Value="False">
									<Setter Property="Width" Value="0" />
								</DataTrigger>
							</Style.Triggers>
						</Style>
					</Grid.Style>
					<Grid.RowDefinitions>
						<RowDefinition />
					</Grid.RowDefinitions>
					<Grid Margin="12" Visibility="{Binding IsDetailPaneExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
						<Grid.RowDefinitions>
							<RowDefinition Height="220" />
							<RowDefinition Height="Auto" />
							<RowDefinition />
						</Grid.RowDefinitions>
						<v:PieChart
							MinHeight="180"
							AutomationProperties.Name="Folder size distribution chart"
							HighlightedSlice="{Binding HighlightedPieSlice, Mode=TwoWay}"
							SliceClicked="PieChart_OnSliceClicked"
							Slices="{Binding PieSlices}" />
						<TextBlock
							Grid.Row="1"
							Margin="0,10,0,6"
							FontWeight="SemiBold"
							Text="{Binding DetailPath}"
							TextWrapping="Wrap" />
						<ListBox Grid.Row="2" ItemsSource="{Binding PieSlices}" SelectedItem="{Binding HighlightedPieSlice, Mode=OneWay}">
							<ListBox.ItemTemplate>
								<DataTemplate>
									<Grid Margin="0,2">
										<Grid.ColumnDefinitions>
											<ColumnDefinition Width="Auto" />
											<ColumnDefinition />
											<ColumnDefinition Width="Auto" />
										</Grid.ColumnDefinitions>
										<Border
											Width="10"
											Height="10"
											Margin="0,0,6,0"
											Background="{Binding Brush}"
											CornerRadius="2" />
										<TextBlock Grid.Column="1" Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
										<TextBlock Grid.Column="2" Margin="8,0,0,0" FontFamily="Cascadia Mono, Consolas" Text="{Binding Bytes, Converter={StaticResource FormatKbSizeConverter}}" />
									</Grid>
								</DataTemplate>
							</ListBox.ItemTemplate>
						</ListBox>
					</Grid>
				</Grid>
			</Grid>

		</Grid>
		<StatusBar Grid.Row="1" Grid.ColumnSpan="3" Background="{DynamicResource DataGridBackgroundBrush}" Foreground="{DynamicResource ForegroundBrush}">
			<StatusBarItem HorizontalContentAlignment="Stretch">
				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="Auto" />
						<ColumnDefinition Width="Auto" />
						<ColumnDefinition Width="Auto" />
						<ColumnDefinition Width="Auto" />
						<ColumnDefinition Width="Auto" />
						<ColumnDefinition Width="*" />
						<ColumnDefinition Width="Auto" />
					</Grid.ColumnDefinitions>
					<TextBlock Grid.Column="0" Margin="0,0,8,0" Text="{Binding ScanStatusText}" />
					<TextBlock Grid.Column="1" Margin="0,0,8,0" Text="{Binding ScanElapsedText}" />
					<TextBlock Grid.Column="2" Margin="0,0,8,0" Text="{Binding ScannedFolderCountText}" />
					<TextBlock Grid.Column="3" Margin="0,0,8,0" Text="{Binding ScanWorkerCountText}" />
					<Button
						Grid.Column="4"
						Margin="0,0,8,0"
						Padding="8,1"
						AutomationProperties.Name="Cancel scanning"
						Click="CancelScan_OnClick"
						Content="Cancel"
						Visibility="{Binding IsScanInProgress, Converter={StaticResource BooleanToVisibilityConverter}}" />
					<TextBlock Grid.Column="5" Margin="0,0,8,0" Text="{Binding CurrentScanPath}" TextTrimming="CharacterEllipsis" />
					<Button
						Grid.Column="6"
						AutomationProperties.Name="Toggle theme mode"
						Click="ThemeToggle_OnClick"
						Style="{StaticResource ThemeToggleButtonStyle}"
						ToolTip="{Binding SelectedThemeMode}">
						<Grid Width="56" Height="28">
							<Border Background="{DynamicResource ToggleTrackBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="14" />
							<Grid Margin="6,0">
								<Grid.ColumnDefinitions>
									<ColumnDefinition />
									<ColumnDefinition />
								</Grid.ColumnDefinitions>
								<TextBlock
									Width="18"
									Height="18"
									HorizontalAlignment="Left"
									VerticalAlignment="Center"
									FontSize="14"
									FontWeight="SemiBold"
									Foreground="{DynamicResource SunBrush}"
									Text="✸"
									TextAlignment="Center" />
								<TextBlock
									Grid.Column="1"
									Width="18"
									Height="18"
									HorizontalAlignment="Right"
									VerticalAlignment="Center"
									FontSize="14"
									FontWeight="SemiBold"
									Foreground="{DynamicResource MoonBrush}"
									RenderTransformOrigin="0.5,0.5"
									Text="☾"
									TextAlignment="Center">
									<TextBlock.RenderTransform>
										<RotateTransform Angle="180" />
									</TextBlock.RenderTransform>
								</TextBlock>
							</Grid>
							<Border
								Width="22"
								Height="22"
								Margin="3"
								Background="{DynamicResource SelectionBrush}"
								BorderBrush="{DynamicResource AccentBrush}"
								BorderThickness="1"
								CornerRadius="11">
								<TextBlock
									Width="18"
									Height="18"
									HorizontalAlignment="Center"
									VerticalAlignment="Center"
									FontSize="14"
									FontWeight="SemiBold"
									Foreground="{DynamicResource SunBrush}"
									RenderTransformOrigin="0.5,0.5"
									TextAlignment="Center">
									<TextBlock.Style>
										<Style TargetType="TextBlock">
											<Setter Property="Text" Value="✸" />
											<Setter Property="RenderTransform">
												<Setter.Value>
													<RotateTransform Angle="0" />
												</Setter.Value>
											</Setter>
											<Style.Triggers>
												<DataTrigger Binding="{Binding IsThemeToggleDark}" Value="True">
													<Setter Property="Text" Value="☾" />
													<Setter Property="Foreground" Value="{DynamicResource MoonBrush}" />
													<Setter Property="RenderTransform">
														<Setter.Value>
															<RotateTransform Angle="180" />
														</Setter.Value>
													</Setter>
												</DataTrigger>
											</Style.Triggers>
										</Style>
									</TextBlock.Style>
								</TextBlock>
								<Border.Style>
									<Style TargetType="Border">
										<Setter Property="HorizontalAlignment" Value="Left" />
										<Style.Triggers>
											<DataTrigger Binding="{Binding IsThemeToggleDark}" Value="True">
												<Setter Property="HorizontalAlignment" Value="Right" />
											</DataTrigger>
										</Style.Triggers>
									</Style>
								</Border.Style>
							</Border>
						</Grid>
					</Button>
				</Grid>
			</StatusBarItem>
		</StatusBar>
	</Grid>

</Window>
