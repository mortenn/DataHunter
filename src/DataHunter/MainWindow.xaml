<Window x:Class="DataHunter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
				xmlns:v="clr-namespace:DataHunter.View"
				xmlns:vm="clr-namespace:DataHunter.ViewModel"
				Title="DataHunter" Height="760" Width="1200" MinHeight="560" MinWidth="900"
				Icon="app.ico"
				Background="{DynamicResource WindowBackgroundBrush}"
				Foreground="{DynamicResource ForegroundBrush}"
				PreviewMouseDown="Window_OnPreviewMouseDown">

	<Window.DataContext>
		<vm:AppContext />
	</Window.DataContext>

	<Window.Resources>

		<v:FormatKbSizeConverter x:Key="FormatKbSizeConverter" />
		<BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

		<Style x:Key="MonospaceCellTextStyle" TargetType="TextBlock">
			<Setter Property="FontFamily" Value="Cascadia Mono, Consolas" />
		</Style>

		<Style x:Key="RightAlignedMonospaceCellTextStyle" TargetType="TextBlock" BasedOn="{StaticResource MonospaceCellTextStyle}">
			<Setter Property="HorizontalAlignment" Value="Stretch" />
			<Setter Property="TextAlignment" Value="Right" />
		</Style>

		<Style x:Key="ThemeToggleButtonStyle" TargetType="Button">
			<Setter Property="Background" Value="Transparent" />
			<Setter Property="BorderThickness" Value="0" />
			<Setter Property="Padding" Value="0" />
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<ContentPresenter />
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<Style x:Key="LandingShortcutButtonStyle" TargetType="Button">
			<Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
			<Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
			<Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
			<Setter Property="BorderThickness" Value="1" />
			<Setter Property="Padding" Value="18,14" />
			<Setter Property="HorizontalContentAlignment" Value="Stretch" />
			<Setter Property="VerticalContentAlignment" Value="Stretch" />
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border x:Name="Root"
						        Background="{TemplateBinding Background}"
						        BorderBrush="{TemplateBinding BorderBrush}"
						        BorderThickness="{TemplateBinding BorderThickness}"
						        CornerRadius="6"
						        SnapsToDevicePixels="True">
							<ContentPresenter HorizontalAlignment="Stretch"
							                  VerticalAlignment="Stretch"
							                  Margin="{TemplateBinding Padding}" />
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter TargetName="Root" Property="Background" Value="{DynamicResource HoverBrush}" />
							</Trigger>
							<Trigger Property="IsPressed" Value="True">
								<Setter TargetName="Root" Property="Background" Value="{DynamicResource DataGridRowSelectedBrush}" />
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<Style x:Key="ShareProgressBarStyle" TargetType="ProgressBar">
			<Setter Property="Minimum" Value="0" />
			<Setter Property="Maximum" Value="1" />
			<Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
			<Setter Property="Background" Value="Transparent" />
			<Setter Property="BorderThickness" Value="0" />
			<Setter Property="IsHitTestVisible" Value="False" />
			<Setter Property="Opacity" Value="0.38" />
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="ProgressBar">
						<Grid ClipToBounds="True" Background="{TemplateBinding Background}">
							<Border x:Name="PART_Track" Background="{TemplateBinding Background}" />
							<Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}" HorizontalAlignment="Left" />
						</Grid>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<HierarchicalDataTemplate DataType="{x:Type vm:MyPc}" ItemsSource="{Binding Drives}">
			<TextBlock Text="{Binding Name}" />
		</HierarchicalDataTemplate>

		<HierarchicalDataTemplate DataType="{x:Type vm:Drive}" ItemsSource="{Binding Folders}">
			<StackPanel Orientation="Horizontal">
				<TextBlock Text="⊘ " Foreground="Red">
					<TextBlock.Style>
						<Style TargetType="TextBlock">
							<Style.Triggers>
								<DataTrigger Binding="{Binding AccessDenied}" Value="False">
									<Setter Property="TextBlock.Visibility" Value="Collapsed" />
								</DataTrigger>
							</Style.Triggers>
						</Style>
					</TextBlock.Style>
				</TextBlock>
				<Grid Width="16" Height="16" Margin="0,0,5,0">
					<Grid.Style>
						<Style TargetType="Grid">
							<Setter Property="Visibility" Value="Collapsed" />
							<Style.Triggers>
								<DataTrigger Binding="{Binding HasActiveScan}" Value="True">
									<Setter Property="Visibility" Value="Visible" />
								</DataTrigger>
							</Style.Triggers>
						</Style>
					</Grid.Style>
					<Path Data="M 8,2 A 6,6 0 1 1 2,8"
					      Stroke="{DynamicResource AccentBrush}"
					      StrokeThickness="2"
					      StrokeStartLineCap="Round"
					      StrokeEndLineCap="Round"
					      Width="16"
					      Height="16"
					      Stretch="None">
						<Path.RenderTransform>
							<RotateTransform CenterX="8" CenterY="8" />
						</Path.RenderTransform>
						<Path.Triggers>
							<EventTrigger RoutedEvent="Loaded">
								<BeginStoryboard>
									<Storyboard RepeatBehavior="Forever">
										<DoubleAnimation Storyboard.TargetProperty="RenderTransform.Angle" From="0" To="360" Duration="0:0:1" />
									</Storyboard>
								</BeginStoryboard>
							</EventTrigger>
						</Path.Triggers>
					</Path>
				</Grid>
				<TextBlock Text="{Binding Info.Name}" />
			</StackPanel>
		</HierarchicalDataTemplate>

		<HierarchicalDataTemplate DataType="{x:Type vm:Folder}" ItemsSource="{Binding Folders}">
			<StackPanel Orientation="Horizontal">
				<TextBlock Text="⊘ " Foreground="Red">
					<TextBlock.Style>
						<Style TargetType="TextBlock">
							<Style.Triggers>
								<DataTrigger Binding="{Binding AccessDenied}" Value="False">
									<Setter Property="TextBlock.Visibility" Value="Collapsed" />
								</DataTrigger>
							</Style.Triggers>
						</Style>
					</TextBlock.Style>
				</TextBlock>
				<Grid Width="14" Height="14" Margin="0,0,5,0">
					<Grid.Style>
						<Style TargetType="Grid">
							<Setter Property="Visibility" Value="Collapsed" />
							<Style.Triggers>
								<DataTrigger Binding="{Binding Scanning}" Value="True">
									<Setter Property="Visibility" Value="Visible" />
								</DataTrigger>
							</Style.Triggers>
						</Style>
					</Grid.Style>
					<Path Data="M 7,1 A 6,6 0 1 1 1,7"
					      Stroke="{DynamicResource AccentBrush}"
					      StrokeThickness="2"
					      StrokeStartLineCap="Round"
					      StrokeEndLineCap="Round"
					      Width="14"
					      Height="14"
					      Stretch="None">
						<Path.RenderTransform>
							<RotateTransform CenterX="7" CenterY="7" />
						</Path.RenderTransform>
						<Path.Triggers>
							<EventTrigger RoutedEvent="Loaded">
								<BeginStoryboard>
									<Storyboard RepeatBehavior="Forever">
										<DoubleAnimation Storyboard.TargetProperty="RenderTransform.Angle" From="0" To="360" Duration="0:0:1" />
									</Storyboard>
								</BeginStoryboard>
							</EventTrigger>
						</Path.Triggers>
					</Path>
				</Grid>
				<Grid Width="16" Height="16" Margin="0,0,5,0">
					<Path Data="M 2,5 L 7,5 L 8,6 L 14,6 L 14,13 L 2,13 Z"
					      Stroke="{DynamicResource SecondaryForegroundBrush}"
					      Fill="Transparent"
					      StrokeThickness="1.2"
					      StrokeLineJoin="Round" />
					<Grid.Style>
						<Style TargetType="Grid">
							<Setter Property="Visibility" Value="Visible" />
							<Style.Triggers>
								<DataTrigger Binding="{Binding Scanning}" Value="True">
									<Setter Property="Visibility" Value="Collapsed" />
								</DataTrigger>
							</Style.Triggers>
						</Style>
					</Grid.Style>
				</Grid>
				<!--<TextBlock Text="📁" Margin="0,0,5,0">
					<TextBlock.Style>
						<Style TargetType="TextBlock">
							<Setter Property="Visibility" Value="Visible" />
							<Style.Triggers>
								<DataTrigger Binding="{Binding Scanning}" Value="True">
									<Setter Property="Visibility" Value="Collapsed" />
								</DataTrigger>
							</Style.Triggers>
						</Style>
					</TextBlock.Style>
				</TextBlock>-->
				<TextBlock Text="{Binding Info.Name}">
					<TextBlock.Style>
						<Style>
							<Style.Triggers>
								<DataTrigger Binding="{Binding IsVirtual}" Value="True">
									<Setter Property="TextBlock.Opacity" Value="0.5" />
								</DataTrigger>
							</Style.Triggers>
						</Style>
					</TextBlock.Style>
				</TextBlock>
			</StackPanel>
		</HierarchicalDataTemplate>

		<Style TargetType="{x:Type TreeViewItem}" BasedOn="{StaticResource {x:Type TreeViewItem}}">
			<Setter Property="IsExpanded" Value="{Binding IsExpanded}" />
			<Setter Property="IsSelected" Value="{Binding IsSelected}" />
		</Style>

	</Window.Resources>
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="250" />
			<ColumnDefinition Width="Auto" />
			<ColumnDefinition />
		</Grid.ColumnDefinitions>

		<TreeView Grid.Column="0" ItemsSource="{Binding TreeRoots}" Name="TreeView" SelectedItemChanged="TreeView_OnSelectedItemChanged" />

		<GridSplitter Width="4" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Stretch" ShowsPreview="True" Background="{DynamicResource BorderBrush}" />

		<Grid Column="2" Background="{DynamicResource WindowBackgroundBrush}">
			<Grid.Style>
				<Style>
					<Setter Property="UIElement.Visibility" Value="Collapsed" />
					<Style.Triggers>
						<DataTrigger Binding="{Binding SelectedFolder}" Value="{x:Null}">
							<Setter Property="UIElement.Visibility" Value="Visible" />
						</DataTrigger>
					</Style.Triggers>
				</Style>
			</Grid.Style>

			<StackPanel Width="520" VerticalAlignment="Center" HorizontalAlignment="Center">
				<TextBlock Text="Where should DataHunter look first?" FontSize="24" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,8" />
				<TextBlock Text="Pick a common hot spot, or choose a drive from the tree." Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="14" Margin="0,0,0,24" />
				<ItemsControl ItemsSource="{Binding LandingShortcuts}">
					<ItemsControl.ItemsPanel>
						<ItemsPanelTemplate>
							<UniformGrid Columns="2" />
						</ItemsPanelTemplate>
					</ItemsControl.ItemsPanel>
					<ItemsControl.ItemTemplate>
						<DataTemplate>
							<Button Click="LandingShortcut_OnClick" Style="{StaticResource LandingShortcutButtonStyle}" Margin="4">
								<Grid HorizontalAlignment="Stretch">
									<Grid.RowDefinitions>
										<RowDefinition Height="Auto" />
										<RowDefinition Height="Auto" />
										<RowDefinition Height="Auto" />
									</Grid.RowDefinitions>
									<TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="14" HorizontalAlignment="Left" />
									<TextBlock Grid.Row="1" Text="{Binding Description}" Foreground="{DynamicResource SecondaryForegroundBrush}" HorizontalAlignment="Left" TextWrapping="Wrap" Margin="0,4,0,0" />
									<TextBlock Grid.Row="2" Text="{Binding FullName}" Foreground="{DynamicResource SecondaryForegroundBrush}" HorizontalAlignment="Left" FontFamily="Cascadia Mono, Consolas" FontSize="11" TextTrimming="CharacterEllipsis" Margin="0,8,0,0" />
								</Grid>
							</Button>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>
			</StackPanel>

		</Grid>

		<Grid Grid.Column="2" Background="{DynamicResource WindowBackgroundBrush}">
			<Grid.Style>
				<Style>
					<Setter Property="UIElement.Visibility" Value="Collapsed" />
					<Style.Triggers>
						<DataTrigger Binding="{Binding SelectedFolder.AccessDenied}" Value="True">
							<Setter Property="UIElement.Visibility" Value="Visible" />
						</DataTrigger>
					</Style.Triggers>
				</Style>
			</Grid.Style>
			<TextBlock Text="⊘ Access Denied" Foreground="Red" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" />
		</Grid>

		<Grid Grid.Column="2">
			<Grid.Style>
				<Style>
					<Style.Triggers>
						<DataTrigger Binding="{Binding SelectedFolder}" Value="{x:Null}">
							<Setter Property="UIElement.Visibility" Value="Collapsed" />
						</DataTrigger>
						<DataTrigger Binding="{Binding SelectedFolder.AccessDenied}" Value="True">
							<Setter Property="UIElement.Visibility" Value="Collapsed" />
						</DataTrigger>
					</Style.Triggers>
				</Style>
			</Grid.Style>
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
				<RowDefinition />
			</Grid.RowDefinitions>

			<StackPanel Grid.Row="0" Background="Transparent" Orientation="Horizontal" Margin="8,8,8,4">
				<Button Content="⬑" Command="{Binding NavigateCommand}" FontSize="16" Margin="2" />
				<Button Content="↻" Command="{Binding RefreshCommand}" FontSize="16" Margin="0,2" />
				<Button Content="Open in explorer" Command="{Binding OpenCommand}" FontSize="16" Margin="0,2" />
			</StackPanel>

			<ListBox Grid.Row="1" ItemsSource="{Binding SelectedFolder.Path}"
				ScrollViewer.HorizontalScrollBarVisibility="Disabled"
				ScrollViewer.VerticalScrollBarVisibility="Disabled">
				<ListBox.ItemsPanel>
					<ItemsPanelTemplate>
						<StackPanel Orientation="Horizontal" />
					</ItemsPanelTemplate>
				</ListBox.ItemsPanel>
				<ListBox.ItemTemplate>
					<DataTemplate>
						<Button Content="{Binding Info.Name}" Click="NavigateAction" Background="Transparent" BorderBrush="Transparent" FontSize="16" Margin="0" />
					</DataTemplate>
				</ListBox.ItemTemplate>
			</ListBox>

			<StackPanel Grid.Row="2" Orientation="Horizontal" Background="Transparent" TextBlock.Foreground="{DynamicResource ForegroundBrush}" TextBlock.FontSize="14" Margin="8,4">
				<TextBlock Text="Files in this folder: " Margin="0,2" FontSize="14" />
				<TextBlock Text="{Binding SelectedFolder.Files,Converter={StaticResource FormatKbSizeConverter}}" FontSize="14" Margin="0,2" />
				<TextBlock Text=" Including subfolders: " Margin="0,2" FontSize="14" />
				<TextBlock Text="{Binding SelectedFolder.Bytes,Converter={StaticResource FormatKbSizeConverter}}" FontSize="14" Margin="0,2" />
			</StackPanel>

			<Grid Grid.Row="3">
				<Grid.ColumnDefinitions>
					<ColumnDefinition />
					<ColumnDefinition Width="Auto" />
					<ColumnDefinition Width="Auto" />
				</Grid.ColumnDefinitions>

				<Grid Grid.Column="0">
				<DataGrid ItemsSource="{Binding Content}" SelectedItem="{Binding SelectedContentFolder,Mode=TwoWay}" AutoGenerateColumns="False"
				          EnableRowVirtualization="True" EnableColumnVirtualization="True"
				          VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling"
				          ScrollViewer.CanContentScroll="True">
					<DataGrid.Style>
						<Style TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
							<Style.Triggers>
								<DataTrigger Binding="{Binding IsContentLoadDeferred}" Value="True">
									<Setter Property="Visibility" Value="Collapsed" />
								</DataTrigger>
							</Style.Triggers>
						</Style>
					</DataGrid.Style>
					<DataGrid.Columns>
						<DataGridTextColumn Header="Folder" Binding="{Binding Info.Name}" ElementStyle="{StaticResource MonospaceCellTextStyle}" IsReadOnly="True" />
						<DataGridTextColumn Header="Size" Binding="{Binding Bytes,Converter={StaticResource FormatKbSizeConverter}}" ElementStyle="{StaticResource RightAlignedMonospaceCellTextStyle}" IsReadOnly="True" SortDirection="Descending" />
						<DataGridTextColumn Header="% of disk" Binding="{Binding DiskSharePercent,StringFormat={}{0:0.00}%}" ElementStyle="{StaticResource RightAlignedMonospaceCellTextStyle}" IsReadOnly="True" />
					</DataGrid.Columns>
					<DataGrid.RowStyle>
						<Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
							<EventSetter Event="MouseDoubleClick" Handler="NavigateAction" />
							<Setter Property="Template">
								<Setter.Value>
									<ControlTemplate TargetType="DataGridRow">
										<Border BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" SnapsToDevicePixels="True">
											<Grid>
												<ProgressBar Value="{Binding ShareOfParent,Mode=OneWay}">
													<ProgressBar.Style>
														<Style TargetType="ProgressBar" BasedOn="{StaticResource ShareProgressBarStyle}">
															<Style.Triggers>
																<DataTrigger Binding="{Binding HasReliableShareOfParent}" Value="False">
																	<Setter Property="Visibility" Value="Collapsed" />
																</DataTrigger>
															</Style.Triggers>
														</Style>
													</ProgressBar.Style>
												</ProgressBar>
												<SelectiveScrollingGrid>
													<SelectiveScrollingGrid.ColumnDefinitions>
														<ColumnDefinition Width="Auto" />
														<ColumnDefinition Width="*" />
													</SelectiveScrollingGrid.ColumnDefinitions>
													<SelectiveScrollingGrid.RowDefinitions>
														<RowDefinition Height="*" />
														<RowDefinition Height="Auto" />
													</SelectiveScrollingGrid.RowDefinitions>
													<DataGridCellsPresenter Grid.Column="1" ItemsPanel="{TemplateBinding ItemsPanel}" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
													<DataGridDetailsPresenter Grid.Column="1" Grid.Row="1" SelectiveScrollingGrid.SelectiveScrollingOrientation="{Binding AreRowDetailsFrozen,ConverterParameter={x:Static SelectiveScrollingOrientation.Vertical},Converter={x:Static DataGrid.RowDetailsScrollingConverter},RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}" Visibility="{TemplateBinding DetailsVisibility}" />
													<DataGridRowHeader Grid.RowSpan="2" SelectiveScrollingGrid.SelectiveScrollingOrientation="Vertical" Visibility="{Binding HeadersVisibility,ConverterParameter={x:Static DataGridHeadersVisibility.Row},Converter={x:Static DataGrid.HeadersVisibilityConverter},RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}" />
												</SelectiveScrollingGrid>
											</Grid>
										</Border>
									</ControlTemplate>
								</Setter.Value>
							</Setter>
							<Style.Triggers>
								<DataTrigger Binding="{Binding Scanning}" Value="True">
									<Setter Property="TextBlock.FontStyle" Value="Italic" />
									<Setter Property="TextBlock.Opacity" Value="0.5"/>
								</DataTrigger>
								<DataTrigger Binding="{Binding Canceled}" Value="True">
									<Setter Property="TextBlock.FontStyle" Value="Italic" />
									<Setter Property="TextBlock.Opacity" Value="0.55"/>
								</DataTrigger>
								<DataTrigger Binding="{Binding AccessDenied}" Value="True">
									<Setter Property="TextBlock.Opacity" Value="0.5"/>
								</DataTrigger>
								<DataTrigger Binding="{Binding IsVirtual}" Value="True">
									<Setter Property="TextBlock.Opacity" Value="0.5" />
								</DataTrigger>
							</Style.Triggers>
						</Style>
					</DataGrid.RowStyle>
				</DataGrid>
				<Grid Visibility="{Binding IsContentLoadDeferred,Converter={StaticResource BooleanToVisibilityConverter}}">
					<StackPanel Width="420" HorizontalAlignment="Center" VerticalAlignment="Center">
						<TextBlock Text="Large folder" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,8" />
						<TextBlock Text="{Binding ContentLoadWarningText}" Foreground="{DynamicResource SecondaryForegroundBrush}" TextWrapping="Wrap" Margin="0,0,0,18" />
						<Button Content="Load table anyway" Click="LoadLargeFolderTable_OnClick" HorizontalAlignment="Left" Padding="14,6" />
					</StackPanel>
				</Grid>
				</Grid>

				<Grid Grid.Column="1" Width="20">
					<GridSplitter Width="4" HorizontalAlignment="Center" VerticalAlignment="Stretch" ShowsPreview="True" />
					<ToggleButton IsChecked="{Binding IsDetailPaneExpanded,Mode=TwoWay}"
					              Width="18"
					              Height="28"
					              HorizontalAlignment="Center"
					              VerticalAlignment="Top"
					              Margin="0,8,0,0"
					              ToolTip="Show or hide details">
						<ToggleButton.Style>
							<Style TargetType="ToggleButton">
								<Setter Property="Content" Value="‹" />
								<Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
								<Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
								<Setter Property="Foreground" Value="{DynamicResource SecondaryForegroundBrush}" />
								<Setter Property="BorderThickness" Value="1" />
								<Setter Property="Template">
									<Setter.Value>
										<ControlTemplate TargetType="ToggleButton">
											<Border x:Name="Root"
											        Background="{TemplateBinding Background}"
											        BorderBrush="{TemplateBinding BorderBrush}"
											        BorderThickness="{TemplateBinding BorderThickness}"
											        CornerRadius="9">
												<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
											</Border>
											<ControlTemplate.Triggers>
												<Trigger Property="IsMouseOver" Value="True">
													<Setter TargetName="Root" Property="Background" Value="{DynamicResource HoverBrush}" />
												</Trigger>
											</ControlTemplate.Triggers>
										</ControlTemplate>
									</Setter.Value>
								</Setter>
								<Style.Triggers>
									<Trigger Property="IsChecked" Value="True">
										<Setter Property="Content" Value="›" />
									</Trigger>
								</Style.Triggers>
							</Style>
						</ToggleButton.Style>
					</ToggleButton>
				</Grid>

				<Grid Grid.Column="2">
					<Grid.Style>
						<Style TargetType="Grid">
							<Setter Property="Width" Value="320" />
							<Style.Triggers>
								<DataTrigger Binding="{Binding IsDetailPaneExpanded}" Value="False">
									<Setter Property="Width" Value="0" />
								</DataTrigger>
							</Style.Triggers>
						</Style>
					</Grid.Style>
					<Grid.RowDefinitions>
						<RowDefinition />
					</Grid.RowDefinitions>
					<Grid Margin="12" Visibility="{Binding IsDetailPaneExpanded,Converter={StaticResource BooleanToVisibilityConverter}}">
						<Grid.RowDefinitions>
							<RowDefinition Height="220" />
							<RowDefinition Height="Auto" />
							<RowDefinition />
						</Grid.RowDefinitions>
						<v:PieChart Slices="{Binding PieSlices}" HighlightedSlice="{Binding HighlightedPieSlice, Mode=TwoWay}" SliceClicked="PieChart_OnSliceClicked" MinHeight="180" />
						<TextBlock Grid.Row="1" Text="{Binding DetailPath}" FontWeight="SemiBold" Margin="0,10,0,6" TextWrapping="Wrap" />
						<ListBox Grid.Row="2" ItemsSource="{Binding PieSlices}" SelectedItem="{Binding HighlightedPieSlice, Mode=OneWay}">
							<ListBox.ItemTemplate>
								<DataTemplate>
									<Grid Margin="0,2">
										<Grid.ColumnDefinitions>
											<ColumnDefinition Width="Auto" />
											<ColumnDefinition />
											<ColumnDefinition Width="Auto" />
										</Grid.ColumnDefinitions>
										<Border Width="10" Height="10" CornerRadius="2" Background="{Binding Brush}" Margin="0,0,6,0" />
										<TextBlock Grid.Column="1" Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
										<TextBlock Grid.Column="2" Text="{Binding Bytes,Converter={StaticResource FormatKbSizeConverter}}" FontFamily="Cascadia Mono, Consolas" Margin="8,0,0,0" />
									</Grid>
								</DataTemplate>
							</ListBox.ItemTemplate>
						</ListBox>
					</Grid>
				</Grid>
			</Grid>

		</Grid>
		<StatusBar Grid.Row="1" Grid.ColumnSpan="3" Background="{DynamicResource DataGridBackgroundBrush}" Foreground="{DynamicResource ForegroundBrush}">
			<StatusBarItem HorizontalContentAlignment="Stretch">
				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="Auto" />
						<ColumnDefinition Width="Auto" />
						<ColumnDefinition Width="Auto" />
						<ColumnDefinition Width="Auto" />
						<ColumnDefinition Width="Auto" />
						<ColumnDefinition Width="*" />
						<ColumnDefinition Width="Auto" />
					</Grid.ColumnDefinitions>
					<TextBlock Grid.Column="0" Text="{Binding ScanStatusText}" Margin="0,0,8,0" />
					<TextBlock Grid.Column="1" Text="{Binding ScanElapsedText}" Margin="0,0,8,0" />
					<TextBlock Grid.Column="2" Text="{Binding ScannedFolderCountText}" Margin="0,0,8,0" />
					<TextBlock Grid.Column="3" Text="{Binding ScanWorkerCountText}" Margin="0,0,8,0" />
					<Button Grid.Column="4" Content="Cancel" Click="CancelScan_OnClick" Padding="8,1" Margin="0,0,8,0" Visibility="{Binding IsScanInProgress,Converter={StaticResource BooleanToVisibilityConverter}}" />
					<TextBlock Grid.Column="5" Text="{Binding CurrentScanPath}" TextTrimming="CharacterEllipsis" Margin="0,0,8,0" />
					<Button Grid.Column="6" Click="ThemeToggle_OnClick" Style="{StaticResource ThemeToggleButtonStyle}" ToolTip="{Binding SelectedThemeMode}">
						<Grid Width="56" Height="28">
							<Border Background="{DynamicResource ToggleTrackBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="14" />
							<Grid Margin="6,0">
								<Grid.ColumnDefinitions>
									<ColumnDefinition />
									<ColumnDefinition />
								</Grid.ColumnDefinitions>
								<TextBlock Width="18" Height="18" Text="✸" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource SunBrush}" HorizontalAlignment="Left" VerticalAlignment="Center" TextAlignment="Center" />
								<TextBlock Grid.Column="1" Width="18" Height="18" Text="☾" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource MoonBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" TextAlignment="Center" RenderTransformOrigin="0.5,0.5">
									<TextBlock.RenderTransform>
										<RotateTransform Angle="180" />
									</TextBlock.RenderTransform>
								</TextBlock>
							</Grid>
							<Border Width="22" Height="22" Margin="3" Background="{DynamicResource SelectionBrush}" BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1" CornerRadius="11">
								<TextBlock Width="18" Height="18" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource SunBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center" RenderTransformOrigin="0.5,0.5">
									<TextBlock.Style>
										<Style TargetType="TextBlock">
											<Setter Property="Text" Value="✸" />
											<Setter Property="RenderTransform">
												<Setter.Value>
													<RotateTransform Angle="0" />
												</Setter.Value>
											</Setter>
											<Style.Triggers>
												<DataTrigger Binding="{Binding IsThemeToggleDark}" Value="True">
													<Setter Property="Text" Value="☾" />
													<Setter Property="Foreground" Value="{DynamicResource MoonBrush}" />
													<Setter Property="RenderTransform">
														<Setter.Value>
															<RotateTransform Angle="180" />
														</Setter.Value>
													</Setter>
												</DataTrigger>
											</Style.Triggers>
										</Style>
									</TextBlock.Style>
								</TextBlock>
								<Border.Style>
									<Style TargetType="Border">
										<Setter Property="HorizontalAlignment" Value="Left" />
										<Style.Triggers>
											<DataTrigger Binding="{Binding IsThemeToggleDark}" Value="True">
												<Setter Property="HorizontalAlignment" Value="Right" />
											</DataTrigger>
										</Style.Triggers>
									</Style>
								</Border.Style>
							</Border>
						</Grid>
					</Button>
				</Grid>
			</StatusBarItem>
		</StatusBar>
	</Grid>

</Window>
